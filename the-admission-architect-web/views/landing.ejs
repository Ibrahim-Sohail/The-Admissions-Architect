    <%- include('partials/footer') %>

    <div class="modal-overlay" id="enquireModal">
        <div class="modal-content">
            <button class="close-modal" onclick="closeModal()">&times;</button>
            
            <h2>Start Your Journey</h2>
            <p>Fill out the form below and an expert counselor will contact you within 24 hours.</p>


            
            <form class="modal-form" id="leadForm" onsubmit="submitLead(event)">
    <input type="text" name="name" placeholder="Full Name *" required>
    <input type="email" name="email" placeholder="Email Address *" required>
    <input type="tel" name="phone" placeholder="Phone Number (with Country Code) *" required>
    
    <select name="destination" required>
        <option value="" disabled selected>Preferred Study Destination *</option>
        <option value="UK">United Kingdom</option>
        <option value="USA">United States</option>
        <option value="Canada">Canada</option>
        <option value="Australia">Australia</option>
        <option value="Europe">Europe</option>
    </select>

    <select name="level" required>
        <option value="" disabled selected>Study Level *</option>
        <option value="Bachelors">Bachelors (Undergraduate)</option>
        <option value="Masters">Masters (Postgraduate)</option>
        <option value="PhD">PhD</option>
    </select>

    <button type="submit" class="calc-btn-primary" id="submitBtn" style="border:none; margin-top: 10px; cursor: pointer;">
        Submit Enquiry
    </button>
</form>
          
            
            <div id="successMessage" style="display: none; text-align: center; padding: 20px 0;">
                <i class="material-icons" style="font-size: 48px; color: #4CAF50; margin-bottom: 10px;">check_circle</i>
                <h3 style="color: #333; margin:0;">Thank You!</h3>
                <p style="color: #666; margin-top: 5px;">We have received your details. Our team will reach out to you shortly.</p>
            </div>
        </div>
    </div>

    <script>
        // 1. Navbar Scroll Effect
        window.addEventListener('scroll', () => {
            const nav = document.getElementById('navbar');
            const logo = document.getElementById('navLogo');
            const text = document.getElementById('navText');
            // Select all links in the center navbar
            const links = document.querySelectorAll('.landing-nav-links a:not([href="/login"])');
            
            if (window.scrollY > 50) {
                nav.classList.add('scrolled');
                logo.style.filter = 'none'; // Revert to colored logo
                text.style.color = '#1976D2';
            } else {
                nav.classList.remove('scrolled');
                logo.style.filter = 'brightness(0) invert(1)'; // Make white
                text.style.color = 'white';
            }
        });

        // 2. Scroll Animation Observer (Fade In Elements)
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('is-visible');
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.fade-in-section').forEach((el) => observer.observe(el));

        // 3. Number Counter Animation for Stats
        const counters = document.querySelectorAll('.counter');
        const speed = 200; 

        const countObserver = new IntersectionObserver((entries, observer) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const counter = entry.target;
                    const target = +counter.getAttribute('data-target');
                    
                    const updateCount = () => {
                        const count = +counter.innerText.replace(/\D/g, ''); 
                        const inc = target / speed;

                        if (count < target) {
                            counter.innerText = Math.ceil(count + inc) + (target > 1000 ? '+' : '');
                            setTimeout(updateCount, 15);
                        } else {
                            counter.innerText = target + (target >= 75 ? '+' : '');
                            if (target === 12000) counter.innerText = "12k+"; 
                        }
                    };
                    updateCount();
                    observer.unobserve(counter); 
                }
            });
        }, { threshold: 0.5 });

        counters.forEach(counter => countObserver.observe(counter));

        // 4. Modal Logic
        const modal = document.getElementById('enquireModal');
        const leadForm = document.getElementById('leadForm');
        const successMsg = document.getElementById('successMessage');

        function openModal() {
            modal.classList.add('active');
        }

        function closeModal() {
            modal.classList.remove('active');
            setTimeout(() => {
                leadForm.style.display = 'flex';
                successMsg.style.display = 'none';
                leadForm.reset();
                document.getElementById('submitBtn').innerText = "Submit Enquiry";
                document.getElementById('submitBtn').style.opacity = "1";
            }, 300); 
        }

        modal.addEventListener('click', function(e) {
            if (e.target === modal) {
                closeModal();
            }
        });

        async function submitLead(e) {
    e.preventDefault();
    const btn = document.getElementById('submitBtn');
    btn.innerText = "Sending...";
    btn.style.opacity = "0.7";

    const formData = new FormData(leadForm);
    const body = Object.fromEntries(formData.entries());

    try {
        const res = await fetch('/enquire', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body)
        });
        const data = await res.json();
        if (data.success) {
            leadForm.style.display = 'none';
            successMsg.style.display = 'block';
            setTimeout(() => closeModal(), 3000);
        } else {
            btn.innerText = "Submit Enquiry";
            btn.style.opacity = "1";
            alert(data.error || 'Something went wrong. Please try again.');
        }
    } catch (err) {
        btn.innerText = "Submit Enquiry";
        btn.style.opacity = "1";
        alert('Failed to submit. Please try again.');
    }
}
    </script>
</body>
</html>